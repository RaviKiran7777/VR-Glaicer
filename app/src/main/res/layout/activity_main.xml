<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <android.opengl.GLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Bottom Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Move Forward Button -->
        <Button
            android:id="@+id/btnMove"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:alpha="0.75"
            android:backgroundTint="#44000000"
            android:text="MOVE"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <!-- Climate Comparison Toggle -->
        <Button
            android:id="@+id/btnClimate"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:alpha="0.75"
            android:backgroundTint="#442266AA"
            android:text="50 YEARS AGO"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <!-- Sensitivity Toggle -->
        <Button
            android:id="@+id/btnSensitivity"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:alpha="0.75"
            android:backgroundTint="#44AA6622"
            android:text="SENS: HIGH"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>
